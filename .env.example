RUBOT_API_BASE_URL=https://api.openai.com/v1
RUBOT_API_KEY=sk-your-key-here
RUBOT_MODEL=gpt-4o
# Fast model for tool-calling rounds (cheaper, faster). Defaults to RUBOT_MODEL if not set.
RUBOT_FAST_MODEL=gpt-4o-mini
RUBOT_WORKSPACE=workspace
RUBOT_MAX_CONTEXT_TOKENS=120000
RUBOT_MAX_RETRIES=3
RUBOT_CODE_EXEC_TIMEOUT=30
# Telegram bot token (optional, from @BotFather). Leave empty to disable TG.
RUBOT_TELEGRAM_BOT_TOKEN=
